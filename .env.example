# Example environment file for the AI Agent Debate System.
# Copy to `.env` (which is gitignored) and set values ONLY if needed.
# NEVER commit real secrets. The primary provider path (Claude CLI) is login-based
# and needs NO key here.

# Provider mode: mock | claude_cli | api_key
AGENT_DEBATE_PROVIDER=mock

# Search mode: mock | ddgs
AGENT_DEBATE_SEARCH=mock

# Optional: only required if you enable the future "api_key" provider.
# Leave unset when using the login-based Claude CLI (the primary path).
# ANTHROPIC_API_KEY=

# Optional: override the config directory (defaults to ./config).
# AGENT_DEBATE_CONFIG_DIR=config
